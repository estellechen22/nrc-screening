# YouTube Data API v3 密钥 (https://console.cloud.google.com/apis/credentials)
YOUTUBE_API_KEY=

# Perspective API 密钥 (https://developers.perspectiveapi.com/)
PERSPECTIVE_API_KEY=

# 配置接口口令
ADMIN_TOKEN=please_change_me

# 数据库路径 (默认使用项目内的 SQLite)
DATABASE_PATH=./data/screening.db

# 服务端口
PORT=8000

# 日志级别 (DEBUG / INFO / WARNING)
LOG_LEVEL=INFO
